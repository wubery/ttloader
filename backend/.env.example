# Скопируйте в .env и при необходимости поправьте.
DATABASE_URL=sqlite:///./video_poster.db
FRONTEND_URL=http://localhost:5173
TIMEZONE=Europe/Moscow

# Путь к ffmpeg/ffprobe, если не в PATH (Windows пример):
# FFMPEG_BIN=C:/ffmpeg/bin/ffmpeg.exe
# FFPROBE_BIN=C:/ffmpeg/bin/ffprobe.exe
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# Показывать окно браузера при постинге (false = фоновый режим)
HEADLESS=true

# Сколько задач постинга выполнять одновременно
MAX_CONCURRENT_JOBS=2
